# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# downloaded remote avatars (fetched per-run, not source)
/public/figma/avatars/
# live data inputs (the .example template stays committed)
/data/incoming/
# swarm-auto cron idempotency ledger (runtime state; carried via Actions cache)
/data/swarm-auto-ledger.json

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# hero-wave bake intermediates (committed outputs are the .mp4 loops)
/scripts/bake-wave-loop/bake.bundle.js
/public/nickai-social/wave-loop-*-preview.png
/out/wave-loop-frames/
